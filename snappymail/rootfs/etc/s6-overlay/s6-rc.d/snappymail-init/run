#!/usr/bin/with-contenv bashio
# ==============================================================================
# SnappyMail initialization
# ==============================================================================

DATA_DIR="/var/www/snappymail/data"
CONFIG_DIR="${DATA_DIR}/_data_/_default_"
DOMAINS_DIR="${CONFIG_DIR}/domains"

bashio::log.info "Initializing SnappyMail..."

mkdir -p "${DOMAINS_DIR}"
chown -R snappymail:snappymail "${DATA_DIR}"

# Admin password
ADMIN_PASSWORD=$(bashio::config 'admin_password')
echo "${ADMIN_PASSWORD}" > "${CONFIG_DIR}/admin_password.txt"
chmod 600 "${CONFIG_DIR}/admin_password.txt"
chown snappymail:snappymail "${CONFIG_DIR}/admin_password.txt"

# Read config values
DOMAIN=$(bashio::config 'domain')
IMAP_HOST=$(bashio::config 'imap_host')
IMAP_PORT=$(bashio::config 'imap_port')
SMTP_HOST=$(bashio::config 'smtp_host')
SMTP_PORT=$(bashio::config 'smtp_port')

# Write local domain JSON
cat > "${DOMAINS_DIR}/${DOMAIN}.json" << EOF
{
    "IMAP": {
        "host": "${IMAP_HOST}",
        "port": ${IMAP_PORT},
        "type": 1,
        "timeout": 300,
        "shortLogin": false,
        "lowerLogin": true,
        "stripLogin": "",
        "ssl": {
            "verify_peer": false,
            "verify_peer_name": false,
            "allow_self_signed": true,
            "SNI_enabled": true,
            "disable_compression": true,
            "security_level": 1
        }
    },
    "SMTP": {
        "host": "${SMTP_HOST}",
        "port": ${SMTP_PORT},
        "type": 2,
        "timeout": 60,
        "shortLogin": false,
        "lowerLogin": true,
        "ssl": {
            "verify_peer": false,
            "verify_peer_name": false,
            "allow_self_signed": true,
            "SNI_enabled": true,
            "disable_compression": true,
            "security_level": 1
        },
        "useAuth": true,
        "setSender": false
    },
    "whiteList": ""
}
EOF

# Write Gmail domain JSON
cat > "${DOMAINS_DIR}/gmail.com.json" << 'EOF'
{
    "IMAP": {
        "host": "imap.gmail.com",
        "port": 993,
        "type": 1,
        "timeout": 300,
        "shortLogin": false,
        "lowerLogin": true,
        "stripLogin": "",
        "ssl": {
            "verify_peer": false,
            "verify_peer_name": false,
            "allow_self_signed": false,
            "SNI_enabled": true,
            "disable_compression": true,
            "security_level": 1
        }
    },
    "SMTP": {
        "host": "smtp.gmail.com",
        "port": 587,
        "type": 2,
        "timeout": 60,
        "shortLogin": false,
        "lowerLogin": true,
        "ssl": {
            "verify_peer": false,
            "verify_peer_name": false,
            "allow_self_signed": false,
            "SNI_enabled": true,
            "disable_compression": true,
            "security_level": 1
        },
        "useAuth": true,
        "setSender": false
    },
    "whiteList": ""
}
EOF

chown -R snappymail:snappymail "${DOMAINS_DIR}"

bashio::log.info "SnappyMail initialization complete!"

sleep infinity
